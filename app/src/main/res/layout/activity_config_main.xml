<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:background="@color/surface_dark">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="← 返回"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:background="@drawable/bg_btn_grey"
            android:paddingLeft="12dp"
        android:paddingRight="12dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="⚙️ 配置管理"
            android:textColor="@color/primary_blue"
            android:textSize="17sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Tab 选择 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:background="@color/surface_dark">

        <Button
            android:id="@+id/tabDefault"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="默认配置"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:background="@drawable/bg_tab_selected"/>

        <Button
            android:id="@+id/tabAccount"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginLeft="4dp"
        android:layout_marginRight="4dp"
            android:text="账号配置"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:background="@drawable/bg_tab_normal"/>

        <Button
            android:id="@+id/tabTasks"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="任务注册"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:background="@drawable/bg_tab_normal"/>
    </LinearLayout>

    <!-- 内容区域（FrameLayout承载3个面板） -->
    <FrameLayout
        android:id="@+id/contentFrame"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>
