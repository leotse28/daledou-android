<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:padding="16dp">

    <!-- 标题 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🎮 大乐斗助手"
            android:textColor="@color/primary_blue"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvAccountInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="加载中..."
            android:textColor="@color/text_secondary"
            android:textSize="11sp"/>
    </LinearLayout>

    <!-- 状态栏 -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⏸ 就绪"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:background="@drawable/bg_card"
        android:padding="10dp"
        android:layout_marginBottom="14dp"/>

    <!-- 执行按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/btnRunNoon"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="🌞 执行午间任务"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_btn_blue"/>

        <Button
            android:id="@+id/btnRunEvening"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="🌙 执行晚间任务"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_btn_green"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnStop"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_marginBottom="16dp"
        android:text="⏹ 停止任务"
        android:textColor="@color/white"
        android:textSize="13sp"
        android:background="@drawable/bg_btn_red"
        android:alpha="0.5"/>

    <!-- 初始化按钮 -->
    <Button
        android:id="@+id/btnInitEnv"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginBottom="16dp"
        android:text="📁 初始化环境 / 释放模板"
        android:textColor="@color/white"
        android:textSize="13sp"
        android:textStyle="bold"
        android:background="@drawable/bg_btn_orange"/>

    <!-- 功能按钮区 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="管理功能"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:layout_marginBottom="8dp"/>

    <!-- 第一行：Cookie / 配置管理 / 日志 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/btnCookie"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="🍪 Cookie"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:background="@drawable/bg_btn_grey"/>

        <Button
            android:id="@+id/btnConfig"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="⚙️ 配置管理"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:background="@drawable/bg_btn_orange"/>

        <Button
            android:id="@+id/btnLog"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="📋 运行日志"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:background="@drawable/bg_btn_grey"/>
    </LinearLayout>

    <!-- 第二行：连通性测试（独立一行，突出显示） -->
    <Button
        android:id="@+id/btnTest"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="🔗 账号连通性测试"
        android:textColor="@color/white"
        android:textSize="13sp"
        android:textStyle="bold"
        android:background="@drawable/bg_btn_blue"/>

</LinearLayout>
