<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@color/surface_dark"
        android:elevation="4dp">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/btn_back"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:background="@drawable/bg_btn_grey"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="@string/btn_test_connection"
            android:textColor="@color/primary_blue"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btnTestAll"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="测试全部"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:background="@drawable/bg_btn_blue"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"/>
    </LinearLayout>

    <!-- 说明 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="💡 向服务器发送真实请求，验证 Cookie 有效性并获取基本信息"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"/>

    <!-- 全局状态 -->
    <TextView
        android:id="@+id/tvGlobalStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/primary_warm"
        android:textSize="12sp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"/>

    <!-- 账号卡片列表 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <LinearLayout
            android:id="@+id/accountListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>
    </ScrollView>

    <!-- 原始响应日志 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="响应详情"
            android:textColor="@color/text_main"
            android:textSize="13sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btnClearLog"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:text="@string/btn_clear"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:background="@drawable/bg_btn_grey"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"/>
    </LinearLayout>

    <ScrollView
        android:id="@+id/logScrollView"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tvResponseLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="等待测试..."
            android:textColor="@color/text_main"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:lineSpacingMultiplier="1.3"
            android:background="@drawable/bg_log"
            android:padding="12dp"
            android:elevation="1dp"/>
    </ScrollView>

</LinearLayout>
