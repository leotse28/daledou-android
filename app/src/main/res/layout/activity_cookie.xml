<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- 顶部标题栏 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:background="@color/surface_dark">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:text="← 返回"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:background="@drawable/bg_btn_grey"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Cookie 管理中心"
            android:textColor="@color/primary_blue"
            android:textSize="17sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btnSave"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:text="💾 保存"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/bg_btn_blue"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"/>
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 提示卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="12dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💡 操作指引"
                    android:textColor="@color/primary_blue"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="粘贴单条或多条 Cookie。系统将自动提取 newuin 账号。保存后可从主界面选择运行。"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:lineSpacingExtra="2dp"/>
            </LinearLayout>

            <!-- 操作按钮组 (历史、恢复、备份) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/btnHistory"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="📋 历史记录"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:background="@drawable/bg_btn_blue"
                    android:alpha="0.9"/>

                <Button
                    android:id="@+id/btnLocalRestore"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="📥 恢复备份"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:background="@drawable/bg_btn_grey"/>

                <Button
                    android:id="@+id/btnLocalBackup"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="📤 导出备份"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:background="@drawable/bg_btn_orange"/>
            </LinearLayout>

            <!-- 输入区域 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="COOKIE 数据输入"
                android:textColor="@color/text_low_gray"
                android:textSize="11sp"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.1"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:minHeight="240dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="2dp">

                <EditText
                    android:id="@+id/etCookie"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:padding="12dp"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:scrollbars="vertical"
                    android:hint="在此粘贴 Cookie 内容 如\n - openId=0526B37P93216077942B70F76802A8DF; accessToken=FD214B0D171A2CB66E123A1B6B1985FB; newuin=567169927\n - openId=391B87FEB572313EF64C5131333D4F1F; accessToken=11F8A1F695AA7A0328B551DDFD5924B1; newuin=9827610436"
                    android:textColorHint="@color/text_hint"/>
            </LinearLayout>

            <!-- 状态信息 -->
            <TextView
                android:id="@+id/tvMsg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="就绪"
                android:textColor="@color/text_low_gray"
                android:textSize="11sp"
                android:gravity="center"/>

            <!-- 底部占位 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="32dp"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
