    <color name="bg_dark">#F8FAFC</color>
    <color name="surface_dark">#FFFFFF</color>
    <color name="surface_card">@color/surface_card_light</color>
    <color name="primary_blue">@color/primary_indigo</color>
    <color name="primary_blue_dark">@color/primary_indigo_dark</color>
    <color name="accent_green">@color/status_green</color>
    <color name="accent_red">@color/status_red</color>
    <color name="accent_orange">@color/status_orange</color>
    <color name="text_primary">@color/text_main</color>
    <color name="text_secondary">@color/text_sub</color>
    <color name="text_hint">@color/text_hint_light</color>
</resources>
