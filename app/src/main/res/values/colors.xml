<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 极简明亮/高级浅色配色 (Premium Light) -->
    <color name="bg_light">#F8FAFC</color>
    <color name="surface_light">#FFFFFF</color>
    <color name="surface_card_light">#F1F5F9</color>

    <!-- 品牌色：优雅蓝/靛蓝 -->
    <color name="primary_indigo">#6366F1</color>
    <color name="primary_indigo_dark">#4F46E5</color>
    <color name="accent_soft_blue">#38BDF8</color>

    <!-- 文字颜色 -->
    <color name="text_main">#0F172A</color>
    <color name="text_sub">#475569</color>
    <color name="text_hint_light">#94A3B8</color>

    <!-- 状态色 -->
    <color name="status_green">#10B981</color>
    <color name="status_red">#EF4444</color>
    <color name="status_orange">#F59E0B</color>

    <!-- 暖色调 (Warm Palette) - 用于辅助色或替代色 -->
    <color name="primary_warm">#F59E0B</color>
    <color name="primary_dark_warm">#D97706</color>
    <color name="surface_warm">#FFFBEB</color>
    <color name="surface_card_warm">#FEF3C7</color>

    <!-- 灰色调 -->
    <color name="text_low_gray">#94A3B8</color>

    <color name="white">#FFFFFF</color>
